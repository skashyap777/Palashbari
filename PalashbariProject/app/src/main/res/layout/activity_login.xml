<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginActivity">

    <LinearLayout
        android:id="@+id/noInternetLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top"
        android:visibility="gone"
        android:orientation="vertical"
        tools:ignore="MissingConstraints">

        <include layout="@layout/layout_no_internet" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/noInternetLayout"
        app:layout_constraintVertical_bias="0.0">

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="20sp"
        android:orientation="vertical">

        <ImageView
            android:layout_marginTop="120sp"
            android:layout_width="80sp"
            android:scaleType="fitXY"
            android:layout_gravity="center"
            android:layout_height="80sp"
            android:src="@drawable/logo"/>


        <TextView
            android:layout_marginTop="70sp"
            android:layout_width="wrap_content"
            android:layout_gravity="center"
            android:layout_height="wrap_content"
            android:text="Let’s sign you in"
            android:fontFamily="@font/roboto_bold"
            android:textSize="18sp"
            android:textColor="@color/black1"/>


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="5sp"
            android:fontFamily="@font/roboto_light"
            android:text="Please signin to continue with your account"
            android:textColor="@color/black"
            android:textSize="12sp" />


        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/usernameLayout"
            android:layout_marginTop="40dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Username"
            app:hintTextColor="@color/grey2"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="@android:color/transparent"
            app:boxStrokeColor="@color/grey"
            app:boxCornerRadiusTopStart="25sp"
            app:boxCornerRadiusTopEnd="25sp"
            app:boxCornerRadiusBottomStart="25sp"
            app:boxCornerRadiusBottomEnd="25sp">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/userNameEditText"
                android:layout_width="match_parent"
                android:fontFamily="@font/roboto"
                android:textSize="14sp"
                android:textColor="@color/black1"
                android:layout_height="wrap_content"
                android:padding="15dp"/>

        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/passwordLayout"
            android:layout_marginTop="20sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password"
            app:hintTextColor="@color/grey2"
            app:boxBackgroundMode="outline"
            app:boxBackgroundColor="@android:color/transparent"
            app:boxStrokeColor="@color/grey"
            app:boxCornerRadiusTopStart="25sp"
            app:boxCornerRadiusTopEnd="25sp"
            app:boxCornerRadiusBottomStart="25sp"
            app:boxCornerRadiusBottomEnd="25sp"
            app:endIconMode="password_toggle">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/passwordEditText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="15dp"
                android:textSize="14sp"
                android:textColor="@color/black1"
                android:inputType="textPassword"/>
        </com.google.android.material.textfield.TextInputLayout>


        <androidx.cardview.widget.CardView
            android:id="@+id/logIn"
            android:layout_gravity="center"
            android:layout_marginTop="70sp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:cardUseCompatPadding="true"
            app:cardCornerRadius="25sp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/green"
                android:gravity="center"
                android:layout_gravity="center"
                android:orientation="horizontal"
                android:paddingTop="12sp"
                android:paddingBottom="12sp"
                android:paddingRight="25sp"
                android:paddingLeft="25sp">

                <ProgressBar
                    android:visibility="gone"
                    android:layout_width="25sp"
                    android:indeterminateTint="@android:color/white"
                    android:id="@+id/progress"
                    android:layout_height="25sp"
                    android:padding="3sp"
                    android:layout_gravity="center" />


                <TextView
                    android:id="@+id/logInLabel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/roboto_medium"
                    android:text="Signin"
                    android:textAlignment="center"
                    android:textColor="@color/white"
                    android:textSize="15sp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>


    </LinearLayout>

    </ScrollView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>